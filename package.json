{
  "name": "headless-select",
  "namespace": "@verbpatch",
  "description": "Headless select monorepo",
  "type": "module",
  "version": "0.0.1-beta.3",
  "author": "Rameez Raja",
  "license": "LGPL-3.0-or-later",
  "packageManager": "pnpm@10.33.0",
  "keywords": [],
  "scripts": {
    "clean": "pnpm --filter \"./packages/**\" run clean",
    "build": "pnpm --filter \"./packages/**\" -r build && size-limit",
    "build:examples": "pnpm --filter \"./examples/**\" -r build",
    "server:node": "pnpm --filter \"./server/uploader-server\" run start",
    "server-wt:node": "pnpm --filter \"./server/webtransport-server\" run start",
    "dev:examples": "pnpm --filter ",
    "build:all": "pnpm -r build && size-limit",
    "publish": "pnpm --filter \"./packages/**\" -r publish  --no-git-checks --access public --publish-branch main",
    "docs": "typedoc",
    "changeset": "changeset",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "size-limit": [
    {
      "limit": "11 kB",
      "path": "packages/headless-select/dist/index.js"
    }
  ],
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/cli": "^2.30.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@size-limit/file": "^12.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-size": "^0.3.1",
    "rollup-plugin-svelte": "^7.2.3",
    "size-limit": "^12.0.1",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.2"
  }
}
